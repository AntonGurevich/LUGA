<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission 
        android:name="android.permission.ACTIVITY_RECOGNITION" 
        android:description="@string/permission_activity_recognition_desc" />
    <uses-permission 
        android:name="android.permission.BODY_SENSORS" 
        android:description="@string/permission_body_sensors_desc" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission 
        android:name="android.permission.ACCESS_FINE_LOCATION" 
        android:description="@string/permission_location_desc" />
    <uses-permission
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:description="@string/permission_location_desc" />

    <!-- Health Connect (replaces the deprecated Google Fit API): read-only, this app never
         writes fitness data, only reads it to compute wellness tokens. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />

    <!-- Required so HealthConnectClient.getSdkStatus() can detect the Health Connect app
         (Android 13 and below only; on Android 14+ Health Connect is part of the OS). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:allowBackup="true"
        android:name=".Acteamity"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LUGA"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Handle email verification deep links (custom scheme) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="acteamity" android:host="auth" />
            </intent-filter>
            <!-- Handle email verification redirect (https, for links pointing to https://acteamity.com/authentication) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="acteamity.com" android:pathPrefix="/authentication" />
            </intent-filter>
            <!-- Handle password recovery deep link (public/password_recovery.html forwards here) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="acteamity" android:host="reset" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LoginActivity"
            android:label="Acteamity Login"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true">
            <!-- Handle email verification deep links - alternative handler -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="acteamity" android:host="auth" />
            </intent-filter>
            <!-- Handle https://acteamity.com/authentication redirect -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="acteamity.com" android:pathPrefix="/authentication" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RegisterActivity"
            android:label="Acteamity Register"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".RegisterStep1Activity"
            android:label="Acteamity Register - Step 1"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".RegisterStep2Activity"
            android:label="Acteamity Register - Step 2"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity android:name=".ProfileEditActivity"
            android:label="Acteamity Edit Profile"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity android:name=".ui.MainTabActivity"
            android:label="Acteamity"
            android:theme="@style/Theme.LUGA.NoActionBar"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity android:name=".PreLoginActivity"
            android:label="Acteamity"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".StepDataViewActivity"
            android:label="Step Data View"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
        </activity>
        <activity
            android:name=".ForgotPasswordActivity"
            android:label="Reset Password"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".PasswordResetActivity"
            android:label="Reset Password"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".PrivacyDisclosureActivity"
            android:label="Privacy"
            android:theme="@style/Theme.LUGA"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Health Connect requires an app-provided screen explaining fitness data usage,
             shown from the Health Connect app's own permissions UI. Content mirrors
             PrivacyDisclosureActivity / https://acteamity.com/privacy. -->
        <activity
            android:name=".PermissionsRationaleActivity"
            android:label="Privacy"
            android:theme="@style/Theme.LUGA"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".PermissionsRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>