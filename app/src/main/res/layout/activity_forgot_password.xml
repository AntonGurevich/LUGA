<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:background="@color/act_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/app_name"
            app:srcCompat="@drawable/logo_mark" />

        <!-- Form state -->
        <LinearLayout
            android:id="@+id/forgotPasswordFormGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Reset your password"
                android:textAppearance="@style/TextAppearance.Acteamity.Header"
                android:textSize="21sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Enter the email you use to sign in and we'll send you a reset link."
                android:textColor="@color/act_ink_500"
                android:textSize="14sp" />

            <silverbackgarden.example.luga.ui.components.AuthTextInputView
                android:id="@+id/forgotPasswordEmailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:authLabel="EMAIL"
                app:authHint="you@company.com"
                app:authInputType="email" />

            <silverbackgarden.example.luga.ui.components.AuthPrimaryButton
                android:id="@+id/forgotPasswordSubmitButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:authButtonText="Send Reset Link" />

        </LinearLayout>

        <!-- Success state -->
        <LinearLayout
            android:id="@+id/forgotPasswordSuccessGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check your inbox"
                android:textAppearance="@style/TextAppearance.Acteamity.Header"
                android:textSize="21sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="If an account exists for that email, a password reset link is on its way."
                android:textColor="@color/act_ink_500"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/backToSignInLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:text="Back to sign in"
            android:textColor="@color/act_blue_600"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
