<?xml version="1.0" encoding="utf-8"?>
<!-- activity_step_data.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        >

        <TextView
            android:id="@+id/titleLast12Months"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your steps in last 12 months"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="17dp"
            android:textColor="@color/luga_blue"
            />


        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartYear"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginBottom="20dp"
            android:padding="16dp" />

        <LinearLayout
            android:id="@+id/sectionLast30Days"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/titleLast30Days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your steps in last 30 days"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="17dp"
                android:textColor="@color/luga_blue"
                />
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartMonth"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="20dp"
                android:padding="16dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
