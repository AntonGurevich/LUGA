<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:background="@color/act_ink_50">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/app_name"
            app:srcCompat="@drawable/acteamity_logo1" />

        <!-- Form state -->
        <LinearLayout
            android:id="@+id/passwordResetFormGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Choose a new password"
                android:textAppearance="@style/TextAppearance.Acteamity.Header"
                android:textSize="21sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Must be at least 6 characters."
                android:textColor="@color/act_ink_500"
                android:textSize="14sp" />

            <silverbackgarden.example.luga.ui.components.AuthPasswordInputView
                android:id="@+id/newPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:authLabel="NEW PASSWORD"
                app:authHint="At least 6 characters" />

            <silverbackgarden.example.luga.ui.components.AuthPasswordInputView
                android:id="@+id/confirmPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:authLabel="CONFIRM PASSWORD"
                app:authHint="Re-enter password" />

            <silverbackgarden.example.luga.ui.components.AuthPrimaryButton
                android:id="@+id/passwordResetSubmitButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:authButtonText="Reset Password" />

        </LinearLayout>

        <!-- Success state -->
        <LinearLayout
            android:id="@+id/passwordResetSuccessGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password reset successfully!"
                android:textAppearance="@style/TextAppearance.Acteamity.Header"
                android:textSize="21sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Taking you back to sign in..."
                android:textColor="@color/act_ink_500"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Invalid/expired link state -->
        <LinearLayout
            android:id="@+id/passwordResetInvalidGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This link is invalid or expired"
                android:textAppearance="@style/TextAppearance.Acteamity.Header"
                android:textSize="19sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text="Please request a new password reset link from the sign-in screen."
                android:textColor="@color/act_ink_500"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/passwordResetBackToSignInLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:text="Back to sign in"
                android:textColor="@color/act_blue_600"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
