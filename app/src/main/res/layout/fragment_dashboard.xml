<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/act_paper"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: app logo + greeting/date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="34dp"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/logo_mark" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="11dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Acteamity.Label"
                    android:textColor="@color/act_ink_400"
                    android:textSize="10sp"
                    tools:text="THURSDAY · JAN 15" />

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textAppearance="@style/TextAppearance.Acteamity.Header"
                    android:textSize="21sp"
                    tools:text="Hello, there" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/headerBell"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_outline"
                    android:contentDescription="Notifications"
                    android:padding="10dp"
                    app:srcCompat="@drawable/ic_bell" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="1dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_badge_dot" />
            </FrameLayout>
        </LinearLayout>

        <!-- Permission Status Indicators (debug/status toggle, hidden by default) -->
        <LinearLayout
            android:id="@+id/permissionIndicators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/act_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/activityRecognitionIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/activityRecognitionIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Activity Recognition Permission"
                    android:src="@android:drawable/ic_menu_directions" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Activity"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/activityRecognitionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bodySensorsIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/bodySensorsIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Body Sensors Permission"
                    android:src="@android:drawable/ic_menu_compass" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sensors"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/bodySensorsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/healthConnectAvailableIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/healthConnectAvailableIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Health Connect Availability"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Health Connect"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/healthConnectAvailableStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/healthConnectPermissionIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/healthConnectPermissionIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Health Connect Permission Status"
                    android:src="@android:drawable/ic_menu_myplaces" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Permission"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/healthConnectPermissionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Activity rings card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/act_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/act_ink_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/activitiesArrea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="PROGRESS TO NEXT TOKEN"
                    android:textAppearance="@style/TextAppearance.Acteamity.Label" />

                <!-- Activity rings: one row of three equal columns, ring above labels
                     (mirrors iOS DashboardView.activityRingsCard's HStack layout). -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:orientation="horizontal">

                    <!-- Steps column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="86dp"
                            android:layout_height="86dp">

                            <com.mikhaellopez.circularprogressbar.CircularProgressBar
                                android:id="@+id/circularProgressBarSteps"
                                android:layout_width="86dp"
                                android:layout_height="86dp"
                                app:cpb_background_progressbar_color="@color/act_ink_100"
                                app:cpb_background_progressbar_width="8dp"
                                app:cpb_progress="0"
                                app:cpb_progress_direction="to_right"
                                app:cpb_progress_max="10000"
                                app:cpb_progressbar_color="@color/act_blue_500"
                                app:cpb_progressbar_width="8dp"
                                app:cpb_round_border="true" />

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:contentDescription="Steps"
                                android:src="@drawable/run"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Steps"
                            android:textColor="@color/act_ink_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvStepsProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="0/10000"
                            android:textColor="@color/act_ink_500"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Cycling column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="86dp"
                            android:layout_height="86dp">

                            <com.mikhaellopez.circularprogressbar.CircularProgressBar
                                android:id="@+id/circularProgressBarCycling"
                                android:layout_width="86dp"
                                android:layout_height="86dp"
                                app:cpb_background_progressbar_color="@color/act_ink_100"
                                app:cpb_background_progressbar_width="8dp"
                                app:cpb_progress="0"
                                app:cpb_progress_direction="to_right"
                                app:cpb_progress_max="15000"
                                app:cpb_progressbar_color="@color/act_mint_500"
                                app:cpb_progressbar_width="8dp"
                                app:cpb_round_border="true" />

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:contentDescription="Cycling"
                                android:src="@drawable/bike"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Cycling"
                            android:textColor="@color/act_ink_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCyclingProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="0m/15000m"
                            android:textColor="@color/act_ink_500"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Swimming column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="86dp"
                            android:layout_height="86dp">

                            <com.mikhaellopez.circularprogressbar.CircularProgressBar
                                android:id="@+id/circularProgressBarSwimming"
                                android:layout_width="86dp"
                                android:layout_height="86dp"
                                app:cpb_background_progressbar_color="@color/act_ink_100"
                                app:cpb_background_progressbar_width="8dp"
                                app:cpb_progress="0"
                                app:cpb_progress_direction="to_right"
                                app:cpb_progress_max="2000"
                                app:cpb_progressbar_color="@color/act_sky"
                                app:cpb_progressbar_width="8dp"
                                app:cpb_round_border="true" />

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:contentDescription="Swimming"
                                android:src="@drawable/swim"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Swimming"
                            android:textColor="@color/act_ink_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSwimmingProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:text="0m/2000m"
                            android:textColor="@color/act_ink_500"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- View stats pill (mirrors iOS "View stats →": blue-50 bg, blue-700 text) -->
                <TextView
                    android:id="@+id/btnViewStats"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_pill_blue50"
                    android:gravity="center"
                    android:text="View stats  →"
                    android:textColor="@color/act_blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Nudge banner (hidden unless a tracked activity is 70-100% to its next token) -->
                <TextView
                    android:id="@+id/nudgeBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@color/act_mint_50"
                    android:padding="10dp"
                    android:textColor="@color/act_mint_600"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="You're close! Just 500 steps more walking earns you a token." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Token wallet card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tokenWalletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:outlineSpotShadowColor="@color/act_blue_500"
            app:cardBackgroundColor="@color/act_blue_600"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_token_gradient"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card header: medal + title, month label right (iOS parity) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Tokens"
                        app:srcCompat="@drawable/ic_medal" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Wellness Tokens"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWalletMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.14"
                        android:textAllCaps="true"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:text="JULY 2026" />
                </LinearLayout>

                <!-- Two equal token columns with divider (iOS parity) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvExTokensBal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:maxLines="1"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="46sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Reimbursable"
                            android:textColor="#D9FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="4dp"
                        android:background="#38FFFFFF" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNonExTokensBal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:maxLines="1"
                            android:textColor="@color/white"
                            android:textSize="46sp"
                            android:textStyle="bold"
                            tools:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Non-reimbursable"
                            android:textColor="#D9FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Monthly-cap gauge in translucent panel (iOS parity) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_gauge_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvGaugeLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#EBFFFFFF"
                            android:textSize="11.5sp"
                            tools:text="8 of 30 tokens this month" />

                        <TextView
                            android:id="@+id/tokenGaugePercentText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/white"
                            android:textSize="11.5sp"
                            android:textStyle="bold"
                            tools:text="33%" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_gauge_track">

                        <View
                            android:id="@+id/tokenGaugeFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_gauge_fill" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Tokens & earnings CTA (iOS white pill) -->
                <TextView
                    android:id="@+id/btnTokensEarnings"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_pill_white"
                    android:gravity="center"
                    android:text="Tokens &amp; earnings  →"
                    android:textColor="@color/act_blue_700"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pace projection sits below the card, centered (iOS parity) -->
        <TextView
            android:id="@+id/tvPaceProjection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:gravity="center"
            android:textColor="@color/act_ink_500"
            android:textSize="11.5sp"
            android:visibility="gone"
            tools:text="At this pace · ~12 tokens by month end" />

    </LinearLayout>
</ScrollView>
