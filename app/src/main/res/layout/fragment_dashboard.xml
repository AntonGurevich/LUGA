<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/act_ink_50"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: app logo + greeting/date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/acteamity_logo1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Acteamity.Header"
                    android:textSize="21sp"
                    tools:text="Hello, there" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="@style/TextAppearance.Acteamity.Label"
                    tools:text="THURSDAY · JAN 15" />
            </LinearLayout>
        </LinearLayout>

        <!-- Permission Status Indicators (debug/status toggle, hidden by default) -->
        <LinearLayout
            android:id="@+id/permissionIndicators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/act_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/activityRecognitionIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/activityRecognitionIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Activity Recognition Permission"
                    android:src="@android:drawable/ic_menu_directions" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Activity"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/activityRecognitionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bodySensorsIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/bodySensorsIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Body Sensors Permission"
                    android:src="@android:drawable/ic_menu_compass" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sensors"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/bodySensorsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/healthConnectAvailableIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/healthConnectAvailableIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Health Connect Availability"
                    android:src="@android:drawable/ic_menu_share" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Health Connect"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/healthConnectAvailableStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/healthConnectPermissionIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/healthConnectPermissionIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Health Connect Permission Status"
                    android:src="@android:drawable/ic_menu_myplaces" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Permission"
                    android:textColor="@color/act_ink_900"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/healthConnectPermissionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Pending"
                    android:textColor="@color/act_ink_900"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Activity rings card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/act_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/act_ink_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/activitiesArrea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="PROGRESS TO NEXT TOKEN"
                    android:textAppearance="@style/TextAppearance.Acteamity.Label" />

                <!-- Steps Activity Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <com.mikhaellopez.circularprogressbar.CircularProgressBar
                            android:id="@+id/circularProgressBarSteps"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cpb_background_progressbar_color="@color/act_ink_200"
                            app:cpb_background_progressbar_width="5dp"
                            app:cpb_progress="0"
                            app:cpb_progress_direction="to_right"
                            app:cpb_progress_max="10000"
                            app:cpb_progressbar_color="@color/act_blue_500"
                            app:cpb_progressbar_width="7dp"
                            app:cpb_round_border="true" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Steps"
                            android:src="@drawable/run"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Steps"
                            android:textColor="@color/act_ink_900"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvStepsProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/10000"
                            android:textColor="@color/act_ink_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Cycling Activity Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <com.mikhaellopez.circularprogressbar.CircularProgressBar
                            android:id="@+id/circularProgressBarCycling"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cpb_background_progressbar_color="@color/act_ink_200"
                            app:cpb_background_progressbar_width="5dp"
                            app:cpb_progress="0"
                            app:cpb_progress_direction="to_right"
                            app:cpb_progress_max="15000"
                            app:cpb_progressbar_color="@color/act_mint_500"
                            app:cpb_progressbar_width="7dp"
                            app:cpb_round_border="true" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Cycling"
                            android:src="@drawable/bike"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cycling"
                            android:textColor="@color/act_ink_900"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCyclingProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0m/15000m"
                            android:textColor="@color/act_ink_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Swimming Activity Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <com.mikhaellopez.circularprogressbar.CircularProgressBar
                            android:id="@+id/circularProgressBarSwimming"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cpb_background_progressbar_color="@color/act_ink_200"
                            app:cpb_background_progressbar_width="5dp"
                            app:cpb_progress="0"
                            app:cpb_progress_direction="to_right"
                            app:cpb_progress_max="2000"
                            app:cpb_progressbar_color="@color/act_sky"
                            app:cpb_progressbar_width="7dp"
                            app:cpb_round_border="true" />

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:contentDescription="Swimming"
                            android:src="@drawable/swim"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Swimming"
                            android:textColor="@color/act_ink_900"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSwimmingProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0m/2000m"
                            android:textColor="@color/act_ink_500"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Nudge banner (hidden unless a tracked activity is 70-100% to its next token) -->
                <TextView
                    android:id="@+id/nudgeBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@color/act_mint_50"
                    android:padding="10dp"
                    android:textColor="@color/act_mint_600"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="You're close! Just 500 steps more walking earns you a token." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Token wallet card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tokenWalletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/act_blue_600"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvExTokensBal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="serif"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="46sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reimbursable"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNonExTokensBal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Non-reimbursable"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gauge_track">

                    <View
                        android:id="@+id/tokenGaugeFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gauge_fill" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tokenGaugePercentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    tools:text="33%" />

                <TextView
                    android:id="@+id/tvPaceProjection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12.5sp"
                    android:visibility="gone"
                    tools:text="At this pace · ~12 tokens by month end" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
