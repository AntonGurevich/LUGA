<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: the transparent brand mark centered inside the
     108dp canvas, sized to stay within the 66dp central safe zone with the
     brand-book clearspace. Fixed dp size + center gravity preserves the mark's
     1024:885 aspect ratio (never stretch the mark). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="56dp"
        android:height="48dp"
        android:gravity="center"
        android:drawable="@drawable/logo_mark" />
</layer-list>
